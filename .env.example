# ─── Django ───────────────────────────────────────────
SECRET_KEY=change-me-to-a-50-char-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100,10.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ─── Database ─────────────────────────────────────────
POSTGRES_DB=clovup
POSTGRES_USER=clovup
POSTGRES_PASSWORD=clovup_secret
DATABASE_URL=postgres://clovup:clovup_secret@db:5432/clovup

# ─── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── CORS ─────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://192.168.1.100

# ─── JWT ──────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Celery ───────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1

# ─── Email (optional) ────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@clovup.local
DAILY_REPORT_RECIPIENTS=owner@example.com

# ─── Device Agent (fiscal printer bridge) ────────────
DEVICE_AGENT_URL=http://localhost:8001
